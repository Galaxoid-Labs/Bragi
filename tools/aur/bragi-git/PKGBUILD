# Maintainer: Jacob Davis <noreply@example.com>
#
# `bragi-git` — builds whatever is currently on `master`. Rolling. Use
# this if you want to track development; for a known-good release
# install `bragi` (from-source tag) or `bragi-bin` (prebuilt).
#
# `pkgver()` runs after the source clones; it generates a version of
# the form `<latest-tag>.r<commits-since>.g<short-sha>` so users can
# pacman-upgrade between rebuilds.

pkgname=bragi-git
_pkgname=bragi
pkgver=0.0.0
pkgrel=1
pkgdesc="A small GPU-accelerated, vim-flavoured text/code editor (development snapshot)"
arch=('x86_64')
url="https://github.com/Galaxoid-Labs/Bragi"
license=('GPL-3.0-only')

depends=('sdl3' 'sdl3_ttf' 'libvterm')
makedepends=('git' 'odin' 'imagemagick')

provides=("$_pkgname=$pkgver")
conflicts=("$_pkgname" "$_pkgname-bin")

# `git+...` makes makepkg clone the repo into $srcdir/$_pkgname.
# `#branch=` pin would limit to that branch; default is the remote's
# HEAD, which is what we want for a -git package.
source=("$_pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/$_pkgname"
	# `git describe` on a repo with at least one tag emits e.g.
	# `v0.1.0-12-gabc1234`. Convert to PKGBUILD-friendly: strip the
	# leading `v`, swap `-N-g` for `.rN.g`. Falls back to `r<count>.<sha>`
	# if no tags exist yet.
	if git describe --tags --long >/dev/null 2>&1; then
		git describe --tags --long | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
	else
		printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
	fi
}

build() {
	cd "$srcdir/$_pkgname"
	odin build . -o:speed -out:bragi
}

package() {
	cd "$srcdir/$_pkgname"

	install -Dm755 bragi "$pkgdir/usr/bin/$_pkgname"

	install -d "$pkgdir/usr/share/applications"
	cat > "$pkgdir/usr/share/applications/$_pkgname.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Bragi
GenericName=Text Editor
Comment=A small GPU-accelerated, vim-flavoured text/code editor
Exec=$_pkgname %F
Icon=$_pkgname
Terminal=false
Categories=Development;TextEditor;
Keywords=editor;vim;modal;code;text;
StartupWMClass=$_pkgname
StartupNotify=true
EOF

	if [[ -f icon.png ]]; then
		for size in 16 32 48 64 128 256 512; do
			install -d "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps"
			convert icon.png -resize "${size}x${size}" \
				"$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/$_pkgname.png"
		done
		install -Dm644 icon.png "$pkgdir/usr/share/pixmaps/$_pkgname.png"
	fi

	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
}
